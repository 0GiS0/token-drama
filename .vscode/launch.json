{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Dev Server (Astro)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_modules>/**"],
      "serverReadyAction": {
        "pattern": "Local:.+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "startDebugging",
        "name": "🌐 Open in Integrated Browser"
      }
    },
    {
      "name": "🌐 Open in Integrated Browser",
      "type": "editor-browser",
      "request": "launch",
      "url": "http://localhost:4321",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
